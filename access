#!/bin/sh
# Access Eternal - Minimal POSIX dynamic DNS
set -e

# Default to the installed library; overridable via env for development
if [ -z "$LIB" ]; then
    LIB="/usr/local/lib/access"
fi

command="${1:-help}"

# ip and help are read-only: let init.sh skip its root requirement for them
if [ "$command" = "ip" ] || [ "$command" = "help" ]; then
    ACCESS_SKIP_ROOT_CHECK=1
fi

# init.sh is the single source of truth for paths and config
if [ -f "$LIB/init.sh" ]; then
    . "$LIB/init.sh"
fi

# Handle commands
if [ -f "$LIB/$command.sh" ]; then
    sh "$LIB/$command.sh" "$@"
elif [ -f "$LIB/module/$command.sh" ]; then
    module_file="$LIB/module/$command.sh"
    . "$module_file"
    if command -v "main" >/dev/null 2>&1; then
        main "$@"
    else
        printf "Error: Function main not found in module %s\n" "$command"
        exit 1
    fi
else
    printf "Error: Module %s not found\n" "$command"
    exit 1
fi