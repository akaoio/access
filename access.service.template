[Unit]
Description=Access Eternal - Real-time IP Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Restart=always
RestartSec=5
ExecStart=__LIB__/daemon.sh
StandardOutput=append:__LOG__/access.log
StandardError=append:__LOG__/error.log

[Install]
WantedBy=multi-user.target